# ============================================================================
# RestoFlow — Supabase CLI / SERVER-side environment (EXAMPLE — placeholders)
# RF-013 — Supabase project bootstrap + environments + secrets
#
# HOW TO USE
#   1. Copy this file to `supabase/.env.local`  (gitignored — NEVER committed).
#   2. Replace every <PLACEHOLDER> with a REAL value taken from the Supabase
#      dashboard or your secrets manager. NEVER paste a real value into THIS
#      *.example file.
#   3. The Supabase CLI substitutes the `env(VAR)` references found in
#      `supabase/config.toml` from your shell environment / `supabase/.env.local`.
#
# SECURITY — DECISION D-011 / RISK R-003 (see docs/SECURITY_AND_THREAT_MODEL.md)
#   - These are SERVER / CLI-side values. They are NOT shipped to Flutter
#     clients (POS / KDS / dashboard / admin).
#   - The service_role key and the DB password are CRITICAL secrets: a leak
#     bypasses PostgreSQL RLS and breaks tenant isolation. Treat any leak as a
#     compromise — rotate immediately and purge from history.
#   - This file must contain PLACEHOLDERS ONLY. Real values live in
#     `supabase/.env.local`, which is gitignored.
# ============================================================================

# --- Supabase AI inside local Studio (optional) ----------------------------
# Referenced by config.toml [studio] openai_api_key = "env(OPENAI_API_KEY)"
OPENAI_API_KEY=<optional-openai-key-or-leave-blank>

# --- Transactional email / SMTP (only if [auth.email.smtp] is enabled) ------
SENDGRID_API_KEY=<optional-smtp-provider-api-key>

# --- Auth external OAuth provider (only if that provider is enabled) ---------
# Referenced by config.toml [auth.external.apple] secret = "env(...)"
SUPABASE_AUTH_EXTERNAL_APPLE_SECRET=<optional-apple-oauth-secret>

# --- Auth SMS provider (only if [auth.sms.twilio] is enabled) ----------------
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=<optional-twilio-auth-token>

# --- Experimental S3 storage backend (only if used) -------------------------
S3_HOST=<optional-s3-host>
S3_REGION=<optional-s3-region>
S3_ACCESS_KEY=<optional-s3-access-key>
S3_SECRET_KEY=<optional-s3-secret-key>

# NOTE: The local `supabase start` stack also prints an anon key, a
# service_role key and a DB URL via `supabase status`. Those are LOCAL-ONLY
# development credentials, but still never paste them into a committed file.
